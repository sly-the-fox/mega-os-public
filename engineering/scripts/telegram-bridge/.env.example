# Telegram Bridge Configuration
# Copy to .env and fill in values

# Required: Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Required: Comma-separated list of allowed Telegram chat IDs
ALLOWED_CHAT_IDS=

# Optional: Passphrase for second-factor authentication (recommended)
BRIDGE_PASSPHRASE=

# Optional: Max messages per 60-second window per chat (default: 10)
RATE_LIMIT_MAX=10

# Optional: Path to mega-os root (auto-detected if not set)
# MEGA_OS_PATH=

# Optional: Timeout for Claude CLI in seconds (default: 600)
# CLAUDE_TIMEOUT=600

# Optional: Telegram long-poll timeout in seconds (default: 30)
# POLL_TIMEOUT=30

# Optional: Chat ID for cron job notifications (falls back to first ALLOWED_CHAT_IDS)
# NOTIFY_CHAT_ID=

# Optional: Log all messages to chat-log.jsonl (default: true)
LOG_MESSAGES=true
